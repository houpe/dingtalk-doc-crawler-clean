# 钉钉鉴权配置（help.beta.ztocc.com）
# 复制为 .env 并填入真实值。

# 钉钉企业内部应用凭证（在钉钉开放平台获取）
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
# 企业 corpId（钉钉 App 内自动登录用，可选）
DINGTALK_CORP_ID=

# 站点对外域名（拼接钉钉回调 URL 用）
PUBLIC_ORIGIN=https://help.beta.ztocc.com

# Session 签名密钥（务必设为强随机值，勿用默认值）
SESSION_SECRET=
# 是否开启鉴权（默认开启；设为 false 则完全开放，仅开发调试用）
AUTH_REQUIRED=true

# Redis（可选，配置即启用；不配则回退内存存储）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2
